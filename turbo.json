{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "test": {},
    "start": { "dependsOn": ["^build"] },
    "@founderiq/database#build": {
      "env": ["DATABASE_URL"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "JWT_SECRET",
        "COOKIE_SECRET",
        "OPENROUTER_API_KEY",
        "AI_MODEL",
        "R2_ENDPOINT",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_BUCKET_NAME",
        "R2_PUBLIC_URL",
        "PLATFORM_URL",
        "PORT",
        "NODE_ENV",
        "FRONTEND_URL",
        "NEXT_PUBLIC_API_URL"
      ]
    },
    "generate": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
